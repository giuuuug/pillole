		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"postgres": "^3.4.9",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"semantic-release": "^25.0.3",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.2.4",
